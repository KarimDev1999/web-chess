        "/time-controls": {
            "get": {
                "description": "Return the list of standard time control presets",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "game"
                ],
                "summary": "Get available time control presets",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/dto.TimeControlPresetResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
